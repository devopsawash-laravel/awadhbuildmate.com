        <a href="#contact" class="btn-nav-contact">Get Quote</a>
        <div class="mobile-menu-btn" id="mobileMenuBtn"><i class="fas fa-bars"></i></div>
    </div>
</nav>

<!-- Mobile menu -->
<div class="mobile-menu" id="mobileMenu">
    <a href="#home">Home</a>
    <a href="#services">Services</a>
    <a href="#projects">Projects</a>
    <a href="#about">About</a>
    <a href="#contact">Contact</a>
    <div style="margin-top:8px">
        <a href="#contact" class="btn-nav-contact">Get Quote</a>
    </div>
</div>

<!-- ═══ HERO ═══ -->
<section id="home" class="hero">
    <div class="hero-slash"></div>
    <div class="hero-corner"></div>
    <div class="hero-content">
        <div class="hero-eyebrow">Est. 2005 · Uttar Pradesh, India</div>
        <h1>
            Building<br>
            <span style="color:var(--orange)">Steel</span><br>
            <span class="h-outline">Structures</span>
        </h1>
        <div class="hero-bar"></div>
        <p>Specialists in structural fabrication, piping erection, and civil construction. Delivering industrial-grade projects across India with precision, safety, and speed.</p>
        <div class="hero-actions">
            <a href="#projects" class="btn-primary"><i class="fas fa-hard-hat"></i> Our Projects</a>
            <a href="#contact"  class="btn-outline"><i class="fas fa-envelope"></i> Get a Quote</a>
        </div>
        <div class="hero-stats">
            <div class="stat"><div class="num" data-count="18">0</div><div class="lbl">Years Active</div></div>
            <div class="stat"><div class="num" data-count="240">0</div><div class="lbl">Projects Done</div></div>
            <div class="stat"><div class="num" data-count="50">0</div><div class="lbl">Expert Team</div></div>
            <div class="stat"><div class="num" data-count="98">0</div><div class="lbl">% Satisfaction</div></div>
        </div>
    </div>
    <div class="scroll-hint">Scroll Down</div>
</section>

<!-- ═══ TICKER ═══ -->
<div class="ticker-strip">
    <div class="ticker-track">
        <span>Structural Fabrication</span><span>Piping Erection</span>
        <span>UG Piping Works</span><span>Civil Construction</span>
        <span>Boiler Fabrication</span><span>Industrial Projects</span>
        <span>Steel Structures</span><span>Plant Maintenance</span>
        <span>Structural Fabrication</span><span>Piping Erection</span>
        <span>UG Piping Works</span><span>Civil Construction</span>
        <span>Boiler Fabrication</span><span>Industrial Projects</span>
        <span>Steel Structures</span><span>Plant Maintenance</span>
    </div>
</div>

<!-- ═══ SERVICES ═══ -->
<section id="services" class="services-section">
    <div class="reveal"><span class="section-tag">What We Do</span></div>
    <div class="reveal rd1"><h2 class="section-title">Our Core <span class="orange">Services</span></h2></div>
    <div class="reveal rd2"><p class="section-subtitle" style="margin-bottom:0">From structural steel fabrication to underground piping — we handle every phase of industrial construction with unmatched precision and safety.</p></div>
    <div class="services-grid reveal rd3">
        <div class="service-card">
            <div class="svc-num">01</div>
            <div class="svc-icon"><i class="fas fa-industry"></i></div>
            <h3>Structural Fabrication &amp; Erection</h3>
            <p>Custom steel structure design, fabrication and on-site erection for industrial plants, warehouses, and complexes to exact specifications.</p>
            <div class="svc-more">Learn More <i class="fas fa-arrow-right"></i></div>
        </div>
        <div class="service-card">
            <div class="svc-num">02</div>
            <div class="svc-icon"><i class="fas fa-tools"></i></div>
            <h3>Piping Fabrication &amp; Erection</h3>
            <p>Complete above-ground piping systems for oil, gas, water, and process industries. Precision fabrication with certified welders.</p>
            <div class="svc-more">Learn More <i class="fas fa-arrow-right"></i></div>
        </div>
        <div class="service-card">
            <div class="svc-num">03</div>
            <div class="svc-icon"><i class="fas fa-hard-hat"></i></div>
            <h3>UG Piping Works</h3>
            <p>Underground pipeline installation including trenching, laying, backfilling and testing for water supply, sewage, and industrial fluid systems.</p>
            <div class="svc-more">Learn More <i class="fas fa-arrow-right"></i></div>
        </div>
        <div class="service-card">
            <div class="svc-num">04</div>
            <div class="svc-icon"><i class="fas fa-fire"></i></div>
            <h3>Boiler Fabrication &amp; Erection</h3>
            <p>High-pressure boiler fabrication, assembly and erection with full compliance to ASME, IBR, and national safety standards.</p>
            <div class="svc-more">Learn More <i class="fas fa-arrow-right"></i></div>
        </div>
        <div class="service-card">
            <div class="svc-num">05</div>
            <div class="svc-icon"><i class="fas fa-building"></i></div>
            <h3>Civil &amp; RCC Works</h3>
            <p>Foundation work, reinforced concrete structures, piling and civil infrastructure for heavy industrial and commercial projects.</p>
            <div class="svc-more">Learn More <i class="fas fa-arrow-right"></i></div>
        </div>
        <div class="service-card">
            <div class="svc-num">06</div>
            <div class="svc-icon"><i class="fas fa-wrench"></i></div>
            <h3>Shutdown &amp; Maintenance</h3>
            <p>Scheduled plant shutdowns, emergency repairs and routine maintenance to minimize downtime and keep operations at peak efficiency.</p>
            <div class="svc-more">Learn More <i class="fas fa-arrow-right"></i></div>
        </div>
    </div>
</section>

<!-- ═══ PROJECTS GRID ═══ -->
<section id="projects" class="projects-section">
    <div class="projects-header">
        <div>
            <div class="reveal"><span class="section-tag">Our Projects</span></div>
            <div class="reveal rd1"><h2 class="section-title">Construction <span class="orange">In Motion</span></h2></div>
        </div>
        <div class="filter-tabs reveal rd2">
            <button class="filter-tab active" onclick="setFilter(this)">All</button>
            <button class="filter-tab" onclick="setFilter(this)">Structural</button>
            <button class="filter-tab" onclick="setFilter(this)">Piping</button>
            <button class="filter-tab" onclick="setFilter(this)">Civil</button>
        </div>
    </div>

    <div class="projects-grid reveal rd3">
        <div class="project-card">
            <div class="pc-bg pc-bg1">🏗️</div>
            <div class="pc-tag">Featured</div>
            <div class="pc-overlay">
                <div class="pc-type">Structural · 2024</div>
                <div class="pc-name">Structural Fabrication &amp; Erection</div>
                <div class="pc-loc"><i class="fas fa-map-marker-alt" style="color:var(--orange);margin-right:5px"></i>Lucknow Industrial Area, UP</div>
            </div>
        </div>
        <div class="project-card">
            <div class="pc-bg pc-bg2">🔩</div>
            <div class="pc-overlay">
                <div class="pc-type">Piping · 2023</div>
                <div class="pc-name">Piping Fabrication &amp; Erection</div>
                <div class="pc-loc"><i class="fas fa-map-marker-alt" style="color:var(--orange);margin-right:5px"></i>Kanpur, UP</div>
            </div>
        </div>
        <div class="project-card">
            <div class="pc-bg pc-bg3">⛏️</div>
            <div class="pc-overlay">
                <div class="pc-type">Civil · 2023</div>
                <div class="pc-name">UG Piping Works</div>
                <div class="pc-loc"><i class="fas fa-map-marker-alt" style="color:var(--orange);margin-right:5px"></i>Agra, UP</div>
            </div>
        </div>
        <div class="project-card">
            <div class="pc-bg pc-bg4">🔥</div>
            <div class="pc-overlay">
                <div class="pc-type">Boiler · 2022</div>
                <div class="pc-name">Boiler Fabrication &amp; Erection</div>
                <div class="pc-loc"><i class="fas fa-map-marker-alt" style="color:var(--orange);margin-right:5px"></i>Varanasi, UP</div>
            </div>
        </div>
        <div class="project-card">
            <div class="pc-bg pc-bg5">🏭</div>
            <div class="pc-overlay">
                <div class="pc-type">Industrial · 2022</div>
                <div class="pc-name">Plant Construction</div>
                <div class="pc-loc"><i class="fas fa-map-marker-alt" style="color:var(--orange);margin-right:5px"></i>Gorakhpur, UP</div>
            </div>
        </div>
        <div class="project-card">
            <div class="pc-bg pc-bg6">🔧</div>
            <div class="pc-overlay">
                <div class="pc-type">Maintenance · 2023</div>
                <div class="pc-name">Shutdown &amp; Revamp</div>
                <div class="pc-loc"><i class="fas fa-map-marker-alt" style="color:var(--orange);margin-right:5px"></i>Prayagraj, UP</div>
            </div>
        </div>
    </div>
</section>

<!-- ═══ ABOUT ═══ -->
<section id="about" class="about-section">
    <div class="about-inner">
        <div class="about-visual reveal">
            <div class="about-img-box">🏗️</div>
            <div class="about-badge">
                <div class="big">18+</div>
                <div class="sm">Years of<br>Excellence</div>
            </div>
        </div>
        <div>
            <div class="reveal"><span class="section-tag">About Us</span></div>
            <div class="reveal rd1"><h2 class="section-title">Built on <span class="orange">Quality</span> &amp; Trust</h2></div>
            <div class="reveal rd2"><p class="about-text">Founded in Uttar Pradesh, Awadh Buildmate has grown into one of India's trusted names in industrial construction. From steel fabrication to piping systems and civil works — we deliver projects that last decades. Our certified engineers, welders, and project managers bring uncompromising precision to every job.</p></div>
            <div class="values-list reveal rd3">
                <div class="value-item"><div class="vi-icon"><i class="fas fa-certificate"></i></div><div class="vi-text"><h4>ISO Certified Quality</h4><p>All works comply with national and international quality standards.</p></div></div>
                <div class="value-item"><div class="vi-icon"><i class="fas fa-hard-hat"></i></div><div class="vi-text"><h4>Zero Compromise on Safety</h4><p>Rigorous HSE protocols across every site, every single day.</p></div></div>
                <div class="value-item"><div class="vi-icon"><i class="fas fa-clock"></i></div><div class="vi-text"><h4>On-Time Every Time</h4><p>97% of our projects delivered on or before the committed date.</p></div></div>
                <div class="value-item"><div class="vi-icon"><i class="fas fa-tools"></i></div><div class="vi-text"><h4>In-House Fabrication</h4><p>Fully equipped fabrication yard for faster turnaround and cost savings.</p></div></div>
            </div>
        </div>
    </div>
</section>

<!-- ═══ TRUST BAND ═══ -->
<div class="trust-band reveal">
    <div class="trust-label">Trusted by leading industries across India</div>
    <div class="trust-logos">
        <div class="trust-logo">ONGC</div>
        <div class="trust-logo">NTPC</div>
        <div class="trust-logo">BPCL</div>
        <div class="trust-logo">L&amp;T</div>
        <div class="trust-logo">TATA Projects</div>
        <div class="trust-logo">HPCL</div>
    </div>
</div>

<!-- ═══ CONTACT ═══ -->
<section id="contact" class="contact-section">
    <div class="contact-inner">
        <div class="reveal">
            <span class="section-tag">Get In Touch</span>
            <h2 class="contact-h2">Start Your <span class="orange">Project</span> With Us</h2>
            <p class="contact-sub">Our experienced team is ready to assess your requirements and deliver a cost-effective, time-bound solution tailored to your industry.</p>
            <div class="contact-details">
                <div class="contact-item"><div class="ci-icon"><i class="fas fa-phone"></i></div><div><div class="ci-label">Phone</div><div class="ci-val">+91 7275502405</div></div></div>
                <div class="contact-item"><div class="ci-icon"><i class="fas fa-envelope"></i></div><div><div class="ci-label">Email</div><div class="ci-val">awadhbuildmate@gmail.com</div></div></div>
                <div class="contact-item"><div class="ci-icon"><i class="fas fa-map-marker-alt"></i></div><div><div class="ci-label">Location</div><div class="ci-val">Vadodara, Gujarat, India</div></div></div>
                <div class="contact-item"><div class="ci-icon"><i class="fas fa-clock"></i></div><div><div class="ci-label">Working Hours</div><div class="ci-val">Mon–Sat: 9:00 AM – 6:00 PM</div></div></div>
            </div>
        </div>
        <div class="reveal rd2">
            <div class="contact-form">
                <div class="form-row">
                    <div class="form-group"><label>First Name</label><input type="text" placeholder="Your first name"></div>
                    <div class="form-group"><label>Last Name</label><input type="text" placeholder="Your last name"></div>
                </div>
                <div class="form-row">
                    <div class="form-group"><label>Email</label><input type="email" placeholder="you@example.com"></div>
                    <div class="form-group"><label>Phone</label><input type="tel" placeholder="+91 9XXXXXXXXX"></div>
